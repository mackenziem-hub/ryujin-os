+];
+
+const NPC_ACCENT = {
+  ZEUS:'#fde047', HERMES:'#ec4899', HEPHAESTUS:'#fbbf24', ARTEMIS:'#34d399',
+  HESTIA:'#fdba74', ATHENA:'#22d3ee', HECATE:'#a78bfa', APOLLO:'#f9a8d4'
+};
+const NPC_PORTRAIT = (npc) => `/assets/rpg/portraits/${npc.toLowerCase()}.webp`;
+
+const CREW = [
+  { id:'mackenzie', name:'CEO MACK',  img:'/assets/rpg/portraits/crew/mackenzie.webp' },
+  { id:'cat',       name:'CAT',       img:'/assets/rpg/portraits/crew/cat.webp' },
+  { id:'darcy',     name:'DARCY',     img:'/assets/rpg/portraits/crew/darcy.webp' },
+  { id:'diego',     name:'DIEGO',     img:'/assets/rpg/portraits/crew/diego.webp' },
+  { id:'aj',        name:'AJ',        img:'/assets/rpg/portraits/crew/aj.webp' },
+  { id:'pavanjot',  name:'PAVANJOT',  img:'/assets/rpg/portraits/crew/pavanjot.webp' },
+  { id:'melodie',   name:'MELODIE',   img:'/assets/rpg/portraits/crew/melodie.webp' }
+];
+
+// ═════ State ═════
+const state = {
+  view: 'TITLE',
+  focusedSector: 0,
+  snapshot: null,
+  snapshotErr: null,
+  snapshotAt: 0,
+  me: null,
+  ccSessions: [],
+  dialogue: null,        // { speaker, portrait, body, revealed, doneAt }
+  modal: null,           // { kind, focusable[], focusIdx }
+  save: loadSave()
+};
+
+function loadSave() {
+  try { return JSON.parse(localStorage.getItem(SAVE_KEY)) || defaultSave(); }
+  catch { return defaultSave(); }
+}
+function defaultSave() {
+  return { dismissed_quests: [], visited_sectors: [], muted: false, last_visit_at: null };
+}
+function persistSave() {
+  try { localStorage.setItem(SAVE_KEY, JSON.stringify(state.save)); } catch {}
+}
+
+// ═════ DOM helpers (XSS-safe) ═════
+function el(tag, attrs, children) {
+  const e = document.createElement(tag);
+  if (attrs) Object.keys(attrs).forEach(k => {
+    if (k === 'class') e.className = attrs[k];
+    else if (k === 'text') e.textContent = attrs[k];
+    else if (k.startsWith('on') && typeof attrs[k] === 'function') e.addEventListener(k.slice(2), attrs[k]);
+    else if (k === 'style' && typeof attrs[k] === 'object') Object.assign(e.style, attrs[k]);
+    else e.setAttribute(k, attrs[k]);
+  });
+  (children || []).forEach(c => { if (c != null) e.appendChild(typeof c === 'string' ? document.createTextNode(c) : c); });
+  return e;
+}
+const $ = id => document.getElementById(id);
+function fmt$(n) { if (n == null) return '--'; if (n >= 1000) return '$' + Math.round(n/1000) + 'K'; return '$' + Math.round(n); }
+function pct(n) { return n == null ? '--' : Math.round(n * 100) + '%'; }
+
+// ═════ Snapshot normalization ═════
+// Prod /api/snapshot returns { sections: {...}, updated_at }. Unwrap so
+// consumers can read s.revenue, s.tickets, etc. Also reshape pipeline
+// (server returns an array of deals) into the object shape the UI expects,
+// and synthesize an alerts[] from watchdog state since alerts is not in
+// the prod payload.
+function normalizeSnapshot(raw) {
+  if (!raw) return raw;
+  const s = raw.sections ? { ...raw.sections } : { ...raw };
+  if (Array.isArray(s.pipeline)) {
+    const arr = s.pipeline;
+    const openish = arr.filter(d => !/lost|cancelled|won|signed/i.test(d.status || 'open'));
+    s.pipeline = {
+      deals: arr,
+      totalValue: openish.reduce((a, d) => a + (d.value || 0), 0),
+      openDeals: openish.length,
+      top5_deals: openish.slice().sort((a, b) => (b.value || 0) - (a.value || 0)).slice(0, 5)
+    };
+  }
+  if (!Array.isArray(s.alerts)) {
+    const out = [];
+    const wd = s.watchdog || {};
+    if ((wd.tier1Count || 0) > 0) out.push(`Watchdog: ${wd.tier1Count} tier-1 items`);
+    if ((wd.tier2Count || 0) > 5) out.push(`Watchdog: ${wd.tier2Count} tier-2 items`);
+    s.alerts = out;
+  }
+  return s;
+}
+
+// ═════ Data fetches ═════
+async function fetchSnapshot() {
+  try {
+    const r = await fetch(`${API_BASE}/api/snapshot?tenant=${TENANT}`, { credentials: 'omit' });
+    if (!r.ok) throw new Error('snapshot ' + r.status);
+    const raw = await r.json();
+    state.snapshot = normalizeSnapshot(raw);
+    state.snapshotErr = null;
+    state.snapshotAt = Date.now();
+  } catch (e) {
+    state.snapshotErr = String(e.message || e);
+  }
+  renderTopbar();
+  if (state.view === 'MAP') renderMap();
+  if (state.view === 'SECTOR') renderSector();
+}
+async function fetchMe() {
+  try {
+    const r = await fetch(`${API_BASE}/api/me`, { credentials: 'omit' });
+    if (r.ok) state.me = await r.json();
+  } catch {}
+}
+async function fetchCcSessions() {
+  try {
+    const r = await fetch(`${API_BASE}/api/cc-presence?tenant=${TENANT}`, { credentials: 'omit' });
+    if (!r.ok) throw new Error('cc-presence ' + r.status);
+    const data = await r.json();
+    state.ccSessions = Array.isArray(data.sessions) ? data.sessions : [];
+  } catch { state.ccSessions = []; }
+  if (state.view === 'MAP') renderMap();
+  renderWizardPop();
+}
+
+// ═════ Per-god daily line (from snapshot) ═════
+function godLine(npc) {
+  const s = state.snapshot;
+  if (!s) return 'Awaiting today\'s briefing…';
+  const rev = s.revenue || {};
+  const t = s.tickets || {};
+  const pipe = s.pipeline || {};
+  const leads = s.leads || {};
+  const ads = s.metaAds || {};
+  const brief = s.briefing_morning || {};
+  const alerts = s.alerts || [];
+
+  const byStat = t.byStatus || {};
+  const recent = (rev.recentActivity || []).slice(0, 3);
+
+  switch (npc) {
+    case 'ZEUS': {
+      const stat = (brief.status || 'unknown').toUpperCase();
+      const top = brief.top3 && brief.top3[0];
+      const topLine = top ? (top.action || top.title || '') : 'No flagged priorities.';
+      return `Briefing status: ${stat}.\nTop priority: ${topLine}`;
+    }
+    case 'HERMES': {
+      const signed = Math.round((rev.signedRevenue || 0) / 1000);
+      const pipeVal = Math.round((pipe.totalValue || 0) / 1000);
+      const accepted = recent.filter(r => /accepted|signed/i.test(r.action || '')).length;
+      return `Signed $${signed}K MTD. Pipeline $${pipeVal}K across ${pipe.openDeals || 0} open deals. ${accepted ? accepted + ' proposal' + (accepted > 1 ? 's' : '') + ' accepted today.' : 'No new acceptances today.'}`;
+    }
+    case 'HEPHAESTUS': {
+      const open = byStat.open || 0;
+      const active = byStat.active || 0;
+      const overdue = t.overdueCount || 0;
+      return `${active} jobs active. ${open} open. ${overdue} overdue. ${overdue > 20 ? 'The forge is hot.' : 'Workload steady.'}`;
+    }
+    case 'ARTEMIS': {
+      const active = byStat.active || 0;
+      const today = (t.activeToday || []).length;
+      return `${active} active service calls. ${today} on dispatch today. ${active > 5 ? 'Arrows ready.' : 'The hunt is calm.'}`;
+    }
+    case 'HESTIA': {
+      const conv = (state.snapshot.ghl_conversations_24h_count) || (alerts.find(a => /conversation/i.test(a)) ? '?' : 0);
+      const totalTix = t.total || 0;
+      return `${conv || 'a handful of'} conversations updated today. ${totalTix} tickets warm.`;
+    }
+    case 'ATHENA': {
+      const signed = Math.round((rev.signedRevenue || 0) / 1000);
+      const pend = rev.pendingRevenue || 0;
+      const adRoi = brief.kpiScouter && brief.kpiScouter.adROI;
+      const adLine = adRoi ? ` Ad ROI ${adRoi}.` : '';
+      const pendNote = pend === 0 && signed > 0 ? ' Pending revenue accumulator stale, recommend audit.' : '';
+      return `Signed $${signed}K month-to-date. Pending $${Math.round(pend/1000)}K.${adLine}${pendNote}`;
+    }
+    case 'HECATE': {
+      const watchdog = alerts.find(a => /watchdog|cron/i.test(String(a)));
+      const stale = alerts.find(a => /stale/i.test(String(a)));
+      if (watchdog) return `⚠ ${watchdog} Cross the threshold carefully.`;
+      if (stale) return `${stale} Worth a sweep.`;
+      return 'Systems nominal. The keys are quiet.';
+    }
+    case 'APOLLO': {
+      const cpl = ads.avgCPL;
+      const lw = leads.thisWeek || 0;
+      const total = leads.total || 0;
+      return `Lead flow ${lw} this week (${total} all-time). CPL ${cpl != null ? '$' + cpl.toFixed(2) : '?'}. ${lw < 3 ? 'Time to amplify.' : 'Channels singing.'}`;
+    }
+  }
+  return 'Quiet today.';
+}
+
+function sectorStatBlocks(sectorId) {
+  const s = state.snapshot;
+  if (!s) return [{k:'STATUS',v:'loading…'}];
+  const rev = s.revenue || {};
+  const t = s.tickets || {};
+  const pipe = s.pipeline || {};
+  const leads = s.leads || {};
+  const ads = s.metaAds || {};
+  const brief = s.briefing_morning || {};
+  const alerts = s.alerts || [];
+
+  switch (sectorId) {
+    case 'HQ': return [
+      { k:'BRIEFING', v:(brief.status || '--').toUpperCase() },
+      { k:'TOP 3', v: (brief.top3 || []).length },
+      { k:'ALERTS', v: alerts.length },
+      { k:'SECTORS', v: '8' }
+    ];
+    case 'SALES': return [
+      { k:'SIGNED MTD', v: fmt$(rev.signedRevenue) },
+      { k:'PIPELINE', v: fmt$(pipe.totalValue) },
+      { k:'OPEN DEALS', v: pipe.openDeals || 0 },
+      { k:'TOP DEAL', v: pipe.top5_deals && pipe.top5_deals[0] ? fmt$(pipe.top5_deals[0].value) : '--' }
+    ];
+    case 'PRODUCTION': return [
+      { k:'ACTIVE', v: (t.byStatus && t.byStatus.active) || 0 },
+      { k:'OPEN', v: (t.byStatus && t.byStatus.open) || 0 },
+      { k:'OVERDUE', v: t.overdueCount || 0 },
+      { k:'DONE', v: (t.byStatus && t.byStatus.done) || 0 }
+    ];
+    case 'SERVICE': return [
+      { k:'ACTIVE CALLS', v: (t.byStatus && t.byStatus.active) || 0 },
+      { k:'DISPATCH TODAY', v: (t.activeToday || []).length },
+      { k:'UNASSIGNED', v: (t.byAssignee && t.byAssignee.Unassigned) || 0 },
+      { k:'CREW LOAD', v: t.byAssignee ? Object.keys(t.byAssignee).length : 0 }
+    ];
+    case 'CUSTOMER': return [
+      { k:'TICKETS', v: t.total || 0 },
+      { k:'OVERDUE', v: t.overdueCount || 0 },
+      { k:'TOTAL LEADS', v: leads.total || 0 },
+      { k:'CONVERSION', v: leads.conversionRate != null ? leads.conversionRate.toFixed(1) + '%' : '--' }
+    ];
+    case 'FINANCE': return [
+      { k:'SIGNED MTD', v: fmt$(rev.signedRevenue) },
+      { k:'PENDING', v: fmt$(rev.pendingRevenue) },
+      { k:'AD ROI', v: (brief.kpiScouter && brief.kpiScouter.adROI) || '--' },
+      { k:'ACTIVE CAMPAIGNS', v: ads.activeCampaigns || 0 }
+    ];
+    case 'ADMIN': {
+      const watchdog = alerts.find(a => /watchdog|cron/i.test(String(a)));
+      return [
+        { k:'ALERTS', v: alerts.length },
+        { k:'WATCHDOG', v: watchdog ? 'DOWN' : 'OK' },
+        { k:'CRON', v: brief.timestamp ? new Date(brief.timestamp).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'}) : '--' },
+        { k:'TENANT', v: TENANT }
+      ];
+    }
+    case 'MARKETING': return [
+      { k:'AVG CPL', v: ads.avgCPL != null ? '$' + ads.avgCPL.toFixed(2) : '--' },
+      { k:'LEADS THIS WK', v: leads.thisWeek || 0 },
+      { k:'ALL LEADS', v: leads.total || 0 },
+      { k:'CAMPAIGNS', v: ads.activeCampaigns || 0 }
+    ];
+  }
+  return [];
+}
+
+function sectorAlertLevel(sectorId) {
+  const s = state.snapshot;
+  if (!s) return 'ok';
+  const t = s.tickets || {};
+  const alerts = s.alerts || [];
+  const brief = s.briefing_morning || {};
+
+  if (sectorId === 'HQ') {
+    return (brief.status === 'red') ? 'alert' : (brief.status === 'yellow' ? 'warn' : 'ok');
+  }
+  if (sectorId === 'PRODUCTION') {
+    const ov = t.overdueCount || 0;
+    return ov > 20 ? 'alert' : ov > 5 ? 'warn' : 'ok';
+  }
+  if (sectorId === 'ADMIN') {
+    return alerts.find(a => /watchdog|cron|down/i.test(String(a))) ? 'alert' : 'ok';
+  }
+  if (sectorId === 'FINANCE') {
+    const rev = s.revenue || {};
+    return (rev.pendingRevenue === 0 && (rev.signedRevenue || 0) > 0) ? 'warn' : 'ok';
+  }
+  return 'ok';
+}
+
+function sectorHeadline(sectorId) {
+  // One-line headline for map tile
+  const s = state.snapshot;
+  if (!s) return 'loading…';
+  const rev = s.revenue || {};
+  const t = s.tickets || {};
+  const pipe = s.pipeline || {};
+  const ads = s.metaAds || {};
+  const brief = s.briefing_morning || {};
+  const alerts = s.alerts || [];
+  const leads = s.leads || {};
+
+  switch (sectorId) {
+    case 'HQ': return `Briefing ${(brief.status || '?').toUpperCase()}`;
+    case 'SALES': return `${fmt$(rev.signedRevenue)} signed`;
+    case 'PRODUCTION': return `${(t.byStatus && t.byStatus.open) || 0} open · ${t.overdueCount || 0} overdue`;
+    case 'SERVICE': return `${(t.byStatus && t.byStatus.active) || 0} active`;
+    case 'CUSTOMER': return `${t.total || 0} tickets`;
+    case 'FINANCE': return `${fmt$(rev.signedRevenue)} MTD`;
+    case 'ADMIN': {
+      const watchdog = alerts.find(a => /watchdog|cron/i.test(String(a)));
+      return watchdog ? 'WATCHDOG DOWN' : 'systems nominal';
+    }
+    case 'MARKETING': return `CPL $${ads.avgCPL != null ? ads.avgCPL.toFixed(2) : '?'} · ${leads.thisWeek || 0}/wk`;
+  }
+}
+
+// ═════ WebAudio chiptune SFX ═════
+let audioCtx = null;
+function ensureAudio() {
+  if (audioCtx || state.save.muted) return audioCtx;
+  try { audioCtx = new (window.AudioContext || window.webkitAudioContext)(); } catch {}
+  return audioCtx;
+}
+function beep(freq, durMs, type, vol) {
+  if (state.save.muted) return;
+  const a = ensureAudio(); if (!a) return;
+  const t0 = a.currentTime;
+  const o = a.createOscillator();
+  const g = a.createGain();
+  o.type = type || 'square';
+  o.frequency.setValueAtTime(freq, t0);
+  g.gain.setValueAtTime(vol || 0.05, t0);
+  g.gain.exponentialRampToValueAtTime(0.0001, t0 + durMs / 1000);
+  o.connect(g); g.connect(a.destination);
+  o.start(t0); o.stop(t0 + durMs / 1000);
+}
+const sfxStep    = () => beep(220, 50, 'square', 0.03);
+const sfxConfirm = () => { beep(660, 50, 'square', 0.05); setTimeout(() => beep(880, 60, 'square', 0.05), 40); };
+const sfxOpen    = () => { beep(440, 40, 'triangle', 0.05); beep(660, 80, 'triangle', 0.04); };
+const sfxClose   = () => beep(330, 60, 'triangle', 0.04);
+const sfxAdvance = () => beep(990, 20, 'square', 0.025);
+const sfxBoss    = () => { beep(110, 250, 'sawtooth', 0.06); setTimeout(() => beep(82, 350, 'sawtooth', 0.06), 200); };
+['click','keydown','touchstart'].forEach(ev => window.addEventListener(ev, function once() { ensureAudio(); window.removeEventListener(ev, once); }, { once: true }));
+
+// ═════ Topbar render ═════
+function renderTopbar() {
+  const tb = $('topbar');
+  tb.classList.toggle('hidden', state.view === 'TITLE');
+  if (state.view === 'TITLE') return;
+
+  const s = state.snapshot;
+  const stats = $('topbarStats');
+  stats.textContent = '';
+  if (!s) {
+    stats.appendChild(el('span', { class: 'stat-chip', text: 'loading…' }));
+    return;
+  }
+  const rev = s.revenue || {};
+  const t = s.tickets || {};
+  const brief = s.briefing_morning || {};
+  const alerts = s.alerts || [];
+
+  const ageMin = state.snapshotAt ? Math.round((Date.now() - state.snapshotAt) / 60000) : 0;
+  const dot = el('span', { class: 'freshness-dot' + (state.snapshotErr ? ' down' : ageMin > 60 ? ' stale' : '') });
+
+  const chips = [
+    { l: 'CEO MACK', v: 'Lv ' + computeLevel(rev.signedRevenue || 0) },
+    { l: 'MTD', v: fmt$(rev.signedRevenue) },
+    { l: 'TICKETS', v: ((t.byStatus && t.byStatus.open) || 0) + ' open' },
+    { l: 'OVERDUE', v: t.overdueCount || 0, level: (t.overdueCount || 0) > 20 ? 'alert' : (t.overdueCount || 0) > 5 ? 'warn' : '' },
+    { l: 'BRIEF', v: (brief.status || '?').toUpperCase(), level: brief.status === 'red' ? 'alert' : brief.status === 'yellow' ? 'warn' : '' },
+    { l: 'ALERTS', v: alerts.length, level: alerts.length ? 'warn' : '' },
+    { l: 'CC', v: state.ccSessions.length },
+    { l: 'SYNC', v: ageMin + 'm ago' }
+  ];
+  chips.forEach(c => {
+    const chip = el('div', { class: 'stat-chip' + (c.level ? ' ' + c.level : '') }, [
+      el('span', { class: 'label', text: c.l }),
+      el('span', { class: 'value', text: String(c.v) })
+    ]);
+    if (c.l === 'SYNC') chip.insertBefore(dot, chip.firstChild);
+    stats.appendChild(chip);
+  });
+}
+
+function computeLevel(signedRev) {
+  // Simple level curve: each level = $25K signed MTD threshold, max display 99
+  if (!signedRev) return 1;
+  return Math.min(99, Math.max(1, Math.floor(signedRev / 25000) + 1));
+}
+
+// ═════ View transitions ═════
+function setView(v) {
+  ['Title','Map','Sector'].forEach(name => {
+    const id = 'view' + name;
+    const node = $(id);
+    if (!node) return;
+    const isActive = ('VIEW' + name.toUpperCase()).slice(4) === v;
+    node.classList.toggle('active', isActive);
+  });
+  // The above is buggy if names mismatch -- explicit map:
+  $('viewTitle').classList.toggle('active', v === 'TITLE');
+  $('viewMap').classList.toggle('active', v === 'MAP');
+  $('viewSector').classList.toggle('active', v === 'SECTOR');
+  state.view = v;
+  renderTopbar();
+  renderWizardPop();
+}
+
+// ═════ TITLE view ═════
+function enterTitle() {
+  setView('TITLE');
+  $('titlePress').style.display = 'block';
+  $('titleLoading').textContent = state.snapshot ? '✓ live data ready' : 'connecting…';
+  closeDialogue();
+}
+function bootPressStart() {
+  sfxConfirm();
+  $('titlePress').textContent = 'LOADING…';
+  $('titlePress').style.animation = 'none';
+  setTimeout(() => { setView('MAP'); renderMap(); $('titlePress').textContent = 'PRESS START'; $('titlePress').style.animation = ''; }, 380);
+}
+
+// ═════ MAP view ═════
+function renderMap() {
+  const grid = $('mapGrid');
+  grid.textContent = '';
+  SECTORS.forEach((sec, i) => {
+    const lvl = sectorAlertLevel(sec.id);
+    const tile = el('div', {
+      class: 'map-hot' + (i === state.focusedSector ? ' focused' : '') + (lvl === 'alert' ? ' alert' : lvl === 'warn' ? ' warn' : ''),
+      'data-sector': sec.id,
+      onclick: () => { state.focusedSector = i; sfxStep(); enterSector(); },
+      onmouseenter: () => { if (state.focusedSector !== i) { state.focusedSector = i; renderMap(); } }
+    }, [
+      el('div', { class: 'hot-label', text: sec.id }),
+      el('div', { class: 'hot-stat' + (lvl === 'alert' ? ' alert' : lvl === 'warn' ? ' warn' : ''), text: sectorHeadline(sec.id) })
+    ]);
+    // CC wizards stationed here
+    const wizardsHere = state.ccSessions.filter(c => (c.current_sector || '').toUpperCase() === sec.id);
+    if (wizardsHere.length) {
+      tile.appendChild(el('div', { class: 'wizard-pip', title: wizardsHere.map(w => w.user_label || 'Claude').join(', ') }, ['🧙 ', String(wizardsHere.length)]));
+    }
+    grid.appendChild(tile);
+  });
+}
+
+// ═════ SECTOR view ═════
+function enterSector() {
+  const sec = SECTORS[state.focusedSector];
+  if (!sec) return;
+  setView('SECTOR');
+  sfxOpen();
+  if (!state.save.visited_sectors.includes(sec.id)) {
+    state.save.visited_sectors.push(sec.id);
+    persistSave();
+  }
+  state.save.last_visit_at = new Date().toISOString();
+  persistSave();
+  renderSector();
+}
+
+function renderSector() {
+  const sec = SECTORS[state.focusedSector];
+  if (!sec) return;
+  $('sectorBg').style.backgroundImage = `url('${sec.bg}')`;
+
+  $('npcImg').src = NPC_PORTRAIT(sec.npc);
+  $('npcImg').alt = sec.npc;
+  $('npcGreek').textContent = sec.npc;
+  $('npcGreek').style.color = NPC_ACCENT[sec.npc] || '#fde047';
+  $('npcRole').textContent = sec.role;
+
+  const panel = $('sectorStatsPanel');
+  panel.textContent = '';
+  panel.appendChild(el('div', { class: 'eyebrow', text: 'SECTOR · ' + sec.id }));
+  panel.appendChild(el('div', { class: 'head', text: sec.npc + ' · ' + sec.role.toUpperCase(), style: { color: NPC_ACCENT[sec.npc] } }));
+  const grid = el('div', { class: 'sector-stats-grid' });
+  sectorStatBlocks(sec.id).forEach(b => {
+    grid.appendChild(el('div', { class: 'k', text: b.k }));
+    grid.appendChild(el('div', { class: 'v', text: String(b.v) }));
+  });
+  panel.appendChild(grid);
+
+  const actions = $('sectorActions');
+  actions.textContent = '';
+  actions.appendChild(el('button', { class: 'btn-ry primary', text: '◀ MAP', onclick: () => { sfxClose(); setView('MAP'); renderMap(); } }));
+  actions.appendChild(el('button', { class: 'btn-ry', text: 'TALK', onclick: () => { sfxConfirm(); talkToNpc(sec); } }));
+  actions.appendChild(el('button', { class: 'btn-ry', text: 'ENTER LIVE PANEL ▶', onclick: () => { sfxConfirm(); window.location.href = sec.href; } }));
+  actions.appendChild(el('button', { class: 'btn-ry', text: 'QUESTS', onclick: () => { sfxOpen(); openQuestModal(); } }));
+
+  // Auto-talk on first entry per sector (only if we haven't talked to this NPC yet this session)
+  if (!state._spokenTo) state._spokenTo = new Set();
+  if (!state._spokenTo.has(sec.id)) {
+    state._spokenTo.add(sec.id);
+    setTimeout(() => talkToNpc(sec), 300);
+  }
+}
+
+// ═════ DIALOGUE ═════
+function talkToNpc(sec) {
+  const speaker = sec.npc;
+  const body = godLine(speaker);
+  openDialogue({ speaker, accent: NPC_ACCENT[speaker], portrait: NPC_PORTRAIT(speaker), body });
+}
+function openDialogue(d) {
+  state.dialogue = Object.assign({ revealed: 0 }, d);
+  $('dialogue').classList.add('open');
+  $('dialogueSpeaker').textContent = d.speaker;
+  $('dialogueSpeaker').style.color = d.accent || '#fde047';
+  $('dialogueSpeaker').style.borderColor = d.accent || 'var(--cyan)';
+  $('dialogueBody').textContent = '';
+  $('dialogueAdvance').style.display = 'none';
+  if (d.portrait) {
+    $('dialoguePortrait').style.display = 'block';
+    $('dialoguePortraitImg').src = d.portrait;
+  } else {
+    $('dialoguePortrait').style.display = 'none';
+  }
+  // Start typewriter
+  if (state._typewriterTimer) clearInterval(state._typewriterTimer);
+  state._typewriterTimer = setInterval(() => {
+    if (!state.dialogue) { clearInterval(state._typewriterTimer); return; }
+    state.dialogue.revealed += 2;
+    const visible = state.dialogue.body.slice(0, state.dialogue.revealed);
+    $('dialogueBody').textContent = visible;
+    if (state.dialogue.revealed % 8 === 0) sfxAdvance();
+    if (state.dialogue.revealed >= state.dialogue.body.length) {
+      clearInterval(state._typewriterTimer);
+      $('dialogueAdvance').style.display = 'block';
+    }
+  }, 30);
+}
+function closeDialogue() {
+  state.dialogue = null;
+  $('dialogue').classList.remove('open');
+  if (state._typewriterTimer) clearInterval(state._typewriterTimer);
+}
+function advanceDialogue() {
+  if (!state.dialogue) return;
+  if (state.dialogue.revealed < state.dialogue.body.length) {
+    state.dialogue.revealed = state.dialogue.body.length;
+    $('dialogueBody').textContent = state.dialogue.body;
+    $('dialogueAdvance').style.display = 'block';
+    if (state._typewriterTimer) clearInterval(state._typewriterTimer);
+    sfxAdvance();
+  } else {
+    closeDialogue();
+    sfxClose();
+  }
+}
+
+// ═════ MODALS ═════
+function openModal(node, focusable) {
+  $('modal').textContent = '';
+  $('modal').appendChild(node);
+  $('modalBack').classList.add('open');
+  state.modal = { focusable: focusable || [], focusIdx: 0 };
+  refreshModalFocus();
+  sfxOpen();
+}
+function closeModal() {
+  $('modalBack').classList.remove('open');
+  state.modal = null;
+  sfxClose();
+}
+function refreshModalFocus() {
+  if (!state.modal) return;
+  (state.modal.focusable || []).forEach((node, i) => node.classList.toggle('focused', i === state.modal.focusIdx));
+}
+
+function openMainMenu() {
+  const items = [
+    { label: 'QUEST LOG', kind: 'quests' },
+    { label: 'CREW PARTY', kind: 'party' },
+    { label: 'INVENTORY', kind: 'inventory' },
+    { label: 'STRATEGIC MAP', kind: 'map' },
+    { label: 'SETTINGS', kind: 'settings' },
+    { label: 'EXIT TO COCKPIT', kind: 'exit' },
+    { label: 'EXIT TO TITLE', kind: 'title' }
+  ];
+  const body = el('div', {}, [el('h2', { text: 'PAUSE MENU' })]);
+  const focusable = [];
+  items.forEach((it) => {
+    const row = el('div', { class: 'menu-item', onclick: () => handleMenuPick(it.kind) }, [
+      el('span', { class: 'arrow', text: '▶' }),
+      el('span', { text: it.label })
+    ]);
+    focusable.push(row);
+    body.appendChild(row);
+  });
+  body.appendChild(el('div', { class: 'modal-hint', text: '↑↓ select · Z/Enter confirm · X/Esc close · M mute' }));
+  openModal(body, focusable);
+}
+
+function handleMenuPick(kind) {
+  closeModal();
+  if (kind === 'quests') openQuestModal();
+  else if (kind === 'party') openPartyModal();
+  else if (kind === 'inventory') openInventoryModal();
+  else if (kind === 'map') { setView('MAP'); renderMap(); }
+  else if (kind === 'settings') openSettingsModal();
+  else if (kind === 'exit') { try { localStorage.setItem('ry_ui_mode', 'normal'); } catch {} window.location.href = '/command-center.html'; }
+  else if (kind === 'title') { setView('TITLE'); enterTitle(); }
+}
+
+function openQuestModal() {
+  const s = state.snapshot;
+  const briefTop = (s && s.briefing_morning && s.briefing_morning.top3) || [];
+  const activeToday = (s && s.tickets && s.tickets.activeToday) || [];
+
+  const allQuests = [
+    ...briefTop.map((q, i) => ({
+      id: 'brief-' + (q.rank || i),
+      title: q.action || q.title || ('Priority ' + (i+1)),
+      ctx: q.context || q.priority || '',
+      pri: (q.priority === 'top_priority' || q.priority === 'urgent') ? 'urgent' : (q.priority === 'high' ? 'high' : 'normal'),
+      origin: 'BRIEFING'
+    })),
+    ...activeToday.slice(0, 6).map(t => ({
+      id: 'tix-' + t.id,
+      title: t.title || t.id,
+      ctx: (t.assignee || 'unassigned') + ' · ' + (t.days_overdue ? t.days_overdue + 'd overdue' : (t.priority || 'normal')),
+      pri: (t.priority === 'urgent' || (t.days_overdue || 0) > 7) ? 'urgent' : (t.priority === 'high' ? 'high' : 'normal'),
+      origin: 'TICKETS'
+    }))
+  ].filter(q => !state.save.dismissed_quests.includes(q.id));
+
+  const body = el('div', {}, [el('h2', { text: 'QUEST LOG' })]);
+  if (!allQuests.length) {
+    body.appendChild(el('div', { class: 'modal-hint', text: 'No active quests. Either you\'re winning or the briefing hasn\'t fired today.' }));
+  } else {
+    const list = el('div', { class: 'quest-list' });
+    allQuests.forEach(q => {
+      const card = el('div', { class: 'quest-card ' + q.pri }, [
+        el('div', { class: 'pri' }),
+        el('div', { class: 'body' }, [
+          el('div', { class: 'title', text: q.title }),
+          el('div', { class: 'ctx', text: q.origin + ' · ' + q.ctx })
+        ]),
+        el('button', { class: 'dismiss', text: '✕', title: 'Dismiss', onclick: () => {
+          state.save.dismissed_quests.push(q.id);
+          persistSave();
+          openQuestModal();
+        }})
+      ]);
+      list.appendChild(card);
+    });
+    body.appendChild(list);
+  }
+  body.appendChild(el('div', { class: 'modal-hint', text: 'Dismissals persist across sessions. Reset in Settings.' }));
+  openModal(body, []);
+}
+
+function openPartyModal() {
+  const body = el('div', {}, [el('h2', { text: 'CREW PARTY' })]);
+  const grid = el('div', { class: 'party-grid' });
+  CREW.forEach(c => {
+    grid.appendChild(el('div', { class: 'party-card' }, [
+      el('img', { src: c.img, alt: c.name }),
+      el('div', { class: 'name', text: c.name })
+    ]));
+  });
+  body.appendChild(grid);
+  body.appendChild(el('div', { class: 'modal-hint', text: 'Plus Ultra crew roster. Click a portrait to load their dossier (coming soon).' }));
+  openModal(body, []);
+}
+
+function openInventoryModal() {
+  const s = state.snapshot;
+  const recent = (s && s.revenue && s.revenue.recentActivity) || [];
+  const body = el('div', {}, [el('h2', { text: 'RECENT ACTIVITY' })]);
+  if (!recent.length) {
+    body.appendChild(el('div', { class: 'modal-hint', text: 'No recent activity in current snapshot.' }));
+  } else {
+    const list = el('div', { class: 'quest-list' });
+    recent.forEach(r => {
+      list.appendChild(el('div', { class: 'quest-card normal' }, [
+        el('div', { class: 'pri' }),
+        el('div', { class: 'body' }, [
+          el('div', { class: 'title', text: (r.customer || 'Customer') + ' -- ' + (r.action || 'event') }),
+          el('div', { class: 'ctx', text: r.date || '' })
+        ])
+      ]));
+    });
+    body.appendChild(list);
+  }
+  openModal(body, []);
+}
+
+function openSettingsModal() {
+  const body = el('div', {}, [el('h2', { text: 'SETTINGS' })]);
+  const muteRow = el('div', { class: 'menu-item', onclick: () => {
+    state.save.muted = !state.save.muted; persistSave(); openSettingsModal();
+    if (!state.save.muted) sfxConfirm();
+  }}, [
+    el('span', { class: 'arrow', text: '▶' }),
+    el('span', { text: state.save.muted ? 'SFX: MUTED' : 'SFX: ON' })
+  ]);
+  body.appendChild(muteRow);
+  const resetRow = el('div', { class: 'menu-item', onclick: () => {
+    if (confirm('Reset save? Dismissed quests will return.')) { state.save = defaultSave(); persistSave(); closeModal(); toast('Save reset'); }
+  }}, [
+    el('span', { class: 'arrow', text: '▶' }),
+    el('span', { text: 'RESET SAVE' })
+  ]);
+  body.appendChild(resetRow);
+  const closeRow = el('div', { class: 'menu-item', onclick: closeModal }, [
+    el('span', { class: 'arrow', text: '▶' }),
+    el('span', { text: 'CLOSE' })
+  ]);
+  body.appendChild(closeRow);
+  body.appendChild(el('div', { class: 'modal-hint', text: 'Save is local to this browser. Cross-device sync is on the roadmap.' }));
+  openModal(body, [muteRow, resetRow, closeRow]);
+}
+
+// ═════ CC wizard NPC popup ═════
+function renderWizardPop() {
+  // Show wizard popup in SECTOR view if there's an active CC session
+  document.querySelectorAll('.wiz-pop').forEach(n => n.remove());
+  if (state.view !== 'SECTOR' || !state.ccSessions.length) return;
+  const wiz = el('div', {
+    class: 'wiz-pop',
+    title: 'Talk to Claude · ' + state.ccSessions.length + ' active',
+    onclick: openWizardDialogue
+  }, [
+    el('img', { src: '/assets/rpg/portraits/claude-wizard.webp', alt: 'Claude' }),
+    el('div', { class: 'badge', text: String(state.ccSessions.length) })
+  ]);
+  $('app').appendChild(wiz);
+}
+
+function openWizardDialogue() {
+  const sessions = state.ccSessions;
+  const lines = sessions.map(s => {
+    const label = s.user_label || s.session_id.slice(0, 12);
+    const tool = s.last_tool || 'idle';
+    const summ = s.last_action_summary ? ' (' + s.last_action_summary + ')' : '';
+    return '· ' + label + ' · ' + tool + summ;
+  });
+  const body = 'Active Claude Code sessions:\n\n' + lines.join('\n') + '\n\n[Press X to close · M to message]';
+  openDialogue({
+    speaker: 'CLAUDE',
+    accent: '#a78bfa',
+    portrait: '/assets/rpg/portraits/claude-wizard.webp',
+    body
+  });
+}
+
+// ═════ Toasts ═════
+function toast(msg, level) {
+  const t = el('div', { class: 'toast' + (level ? ' ' + level : ''), text: msg });
+  $('toastStack').appendChild(t);
+  setTimeout(() => { t.style.transition = 'opacity .4s'; t.style.opacity = '0'; setTimeout(() => t.remove(), 400); }, 3500);
+}
+
+// ═════ Input ═════
+document.addEventListener('keydown', (e) => {
+  const k = e.key;
+  // Modal-open: ESC/X closes
+  if (state.modal) {
+    if (k === 'Escape' || k === 'x' || k === 'X' || k === 'b' || k === 'B') { e.preventDefault(); closeModal(); return; }
+    if (k === 'ArrowDown' || k === 'ArrowUp') {
+      e.preventDefault();
+      const f = state.modal.focusable || [];
+      if (!f.length) return;
+      state.modal.focusIdx = (state.modal.focusIdx + (k === 'ArrowDown' ? 1 : -1) + f.length) % f.length;
+      refreshModalFocus();
+      return;
+    }
+    if (k === 'Enter' || k === 'z' || k === 'Z') {
+      e.preventDefault();
+      const node = state.modal.focusable[state.modal.focusIdx];
+      if (node && typeof node.click === 'function') node.click();
+      return;
+    }
+    return;
+  }
+  // Dialogue open: any key advances
+  if (state.dialogue) {
+    if (k === 'Escape' || k === 'x' || k === 'X' || k === 'b' || k === 'B') { e.preventDefault(); closeDialogue(); sfxClose(); return; }
+    if (k === 'Enter' || k === 'z' || k === 'Z' || k === ' ') { e.preventDefault(); advanceDialogue(); return; }
+    return;
+  }
+  // TITLE
+  if (state.view === 'TITLE') {
+    if (k === 'Enter' || k === 'z' || k === 'Z' || k === ' ') { e.preventDefault(); bootPressStart(); return; }
+    return;
+  }
+  // MAP
+  if (state.view === 'MAP') {
+    if (k === 'ArrowRight' || k === 'd' || k === 'D') { e.preventDefault(); state.focusedSector = Math.min(7, state.focusedSector + 1); renderMap(); sfxStep(); return; }
+    if (k === 'ArrowLeft' || k === 'a' || k === 'A') { e.preventDefault(); state.focusedSector = Math.max(0, state.focusedSector - 1); renderMap(); sfxStep(); return; }
+    if (k === 'ArrowDown' || k === 's' || k === 'S') { e.preventDefault(); state.focusedSector = Math.min(7, state.focusedSector + 4); renderMap(); sfxStep(); return; }
+    if (k === 'ArrowUp' || k === 'w' || k === 'W') { e.preventDefault(); state.focusedSector = Math.max(0, state.focusedSector - 4); renderMap(); sfxStep(); return; }
+    if (k === 'Enter' || k === 'z' || k === 'Z') { e.preventDefault(); enterSector(); return; }
+  }
+  // SECTOR
+  if (state.view === 'SECTOR') {
+    if (k === 'Escape' || k === 'x' || k === 'X' || k === 'b' || k === 'B') { e.preventDefault(); sfxClose(); setView('MAP'); renderMap(); return; }
+    if (k === 'Enter' || k === 'z' || k === 'Z' || k === 't' || k === 'T') { e.preventDefault(); const sec = SECTORS[state.focusedSector]; if (sec) talkToNpc(sec); return; }
+    if (k === 'q' || k === 'Q') { e.preventDefault(); openQuestModal(); return; }
+  }
+  // Global
+  if (k === 'Escape' && state.view !== 'TITLE') { e.preventDefault(); openMainMenu(); return; }
+  if (k === 'm' || k === 'M') { e.preventDefault(); state.save.muted = !state.save.muted; persistSave(); $('btnMute').style.opacity = state.save.muted ? '0.4' : '1'; if (!state.save.muted) sfxConfirm(); return; }
+});
+
+// Click handlers for global buttons
+document.addEventListener('DOMContentLoaded', () => {
+  $('btnMute').addEventListener('click', () => {
+    state.save.muted = !state.save.muted; persistSave();
+    $('btnMute').style.opacity = state.save.muted ? '0.4' : '1';
+    if (!state.save.muted) sfxConfirm();
+  });
+  $('btnPause').addEventListener('click', () => openMainMenu());
+  $('viewTitle').addEventListener('click', () => { if (state.view === 'TITLE') bootPressStart(); });
+  $('dialogue').addEventListener('click', () => advanceDialogue());
+  $('modalBack').addEventListener('click', (e) => { if (e.target.id === 'modalBack') closeModal(); });
+  $('btnMute').style.opacity = state.save.muted ? '0.4' : '1';
+});
+
+// ═════ Boot ═════
+async function boot() {
+  // Begin parallel data fetch
+  Promise.allSettled([fetchSnapshot(), fetchMe(), fetchCcSessions()]);
+  // Update title-screen status after data lands
+  setTimeout(() => { if ($('titleLoading')) $('titleLoading').textContent = state.snapshot ? '✓ live data ready · press start' : (state.snapshotErr ? '⚠ offline mode · press start' : 'connecting…'); }, 2500);
+  // Refresh loops
+  setInterval(fetchSnapshot, SNAPSHOT_REFRESH_MS);
+  setInterval(fetchCcSessions, CC_REFRESH_MS);
+  // Watchdog alert toast
+  setTimeout(() => {
+    const alerts = (state.snapshot && state.snapshot.alerts) || [];
+    const wd = alerts.find(a => /watchdog|cron/i.test(String(a)));
+    if (wd) { toast(wd, 'amber'); sfxBoss(); }
+  }, 3500);
+}
+boot();
+</script>
+</body>
+</html>
