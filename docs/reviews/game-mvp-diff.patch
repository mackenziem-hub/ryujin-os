+
+<script>
+'use strict';
+
+// ═══════════════════════════════════════════════════════════════
+// RYUJIN OS -- Plus Ultra Operations · Game Shell v1.0
+// ═══════════════════════════════════════════════════════════════
+
+const TENANT = 'plus-ultra';
+const API_BASE = window.location.protocol === 'file:' ? 'https://ryujin-os.vercel.app' : '';
+const SNAPSHOT_REFRESH_MS = 5 * 60 * 1000;
+const CC_REFRESH_MS = 30 * 1000;
+const SAVE_KEY = 'ryujin_game_save_v1';
+
+const SECTORS = [
+  { id:'HQ',        npc:'ZEUS',       role:'Governance',  href:'/command-center.html',         bg:'/assets/rpg/scenes/sectors/hq-throne.webp' },
+  { id:'SALES',     npc:'HERMES',     role:'Messenger',   href:'/sales-cockpit.html',          bg:'/assets/rpg/scenes/sectors/sales-floor.webp' },
+  { id:'PRODUCTION',npc:'HEPHAESTUS', role:'Forge',       href:'/production.html',             bg:'/assets/rpg/scenes/sectors/production-forge.webp' },
+  { id:'SERVICE',   npc:'ARTEMIS',    role:'Hunter',      href:'/service-tickets.html',        bg:'/assets/rpg/scenes/sectors/service-dispatch.webp' },
+  { id:'CUSTOMER',  npc:'HESTIA',     role:'Hearth',      href:'/customers.html',              bg:'/assets/rpg/scenes/sectors/customer-hearth.webp' },
+  { id:'FINANCE',   npc:'ATHENA',     role:'Sage',        href:'/admin.html?page=finance',     bg:'/assets/rpg/scenes/sectors/finance-vault.webp' },
+  { id:'ADMIN',     npc:'HECATE',     role:'Witch',       href:'/administration.html',         bg:'/assets/rpg/scenes/sectors/admin-server.webp' },
