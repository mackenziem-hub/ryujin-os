# ============================================================================
# Ryujin OS - machine .env.local TEMPLATE   (copy to the repo-root .env.local)
# .env.local is gitignored. NEVER commit real secrets.
# Easiest path: run scripts/onboarding/bootstrap.ps1, which fills the path vars
# and validates this file for you.
# ============================================================================

# --- Cross-machine brain: REQUIRED (read + write the shared Supabase spine) ---
# Get these three from Mac (same values as his machine). Treat like passwords.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=PASTE_FROM_MAC
RYUJIN_SERVICE_TOKEN=PASTE_FROM_MAC

# --- This machine's brain paths: REQUIRED (bootstrap.ps1 sets these for you) ---
# RYUJIN_MEMORY_DIR: where the shared MEMORY.md + principle files materialize.
#   It MUST be this machine's Claude Code project memory dir so they auto-load:
#   <home>/.claude/projects/<project-slug>/memory
# RYUJIN_BRAIN_DIR: where SESSION_CONTEXT.md materializes (any local folder).
RYUJIN_MEMORY_DIR=
RYUJIN_BRAIN_DIR=

# --- Per-person spine filter (optional) ---
# RYUJIN_OPERATOR: your short name (e.g. cat). RYUJIN_ROLE: owner | operator.
# Operators' saves default to their own stream; owners broadcast. Unset = see everything.
# RYUJIN_OPERATOR=
# RYUJIN_ROLE=operator

# --- Optional (defaults are correct; uncomment only to override) ---
# RYUJIN_APP_URL=https://ryujin-os.vercel.app
# RYUJIN_TENANT=plus-ultra

# --- Withheld by design ---
# SUPABASE_PAT is intentionally NOT here. Database schema / DDL migrations stay
# with Mac. Ask him to run any migration. See docs/MACHINE_SETUP.md (access model).
