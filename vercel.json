{
  "rewrites": [
    { "source": "/api/agents/:agent((?!daily|weekly|briefing|memory|watchdog|heartbeat|cashflow|peer-audit|cron-daily).*)", "destination": "/api/agents/[agent]?agent=:agent" },
    { "source": "/i/:slug", "destination": "/api/i?u=:slug" },
    { "source": "/(.*)", "destination": "/public/$1" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization, x-tenant-id, x-internal-key" }
      ]
    }
  ],
  "functions": {
    "api/marketing-render.js": {
      "maxDuration": 300,
      "includeFiles": "node_modules/ffmpeg-static/**"
    },
    "api/marketing.js": {
      "maxDuration": 60
    },
    "api/marketing-upload-token.js": {
      "maxDuration": 30
    },
    "api/chat.js": {
      "maxDuration": 60
    },
    "api/proposal-pdf.js": {
      "maxDuration": 60,
      "memory": 2048,
      "includeFiles": "node_modules/@sparticuz/chromium/**"
    },
    "api/contract-pdf.js": {
      "maxDuration": 60,
      "memory": 2048,
      "includeFiles": "node_modules/@sparticuz/chromium/**"
    },
    "api/docs-pdf.js": {
      "maxDuration": 60,
      "memory": 2048,
      "includeFiles": "node_modules/@sparticuz/chromium/**"
    },
    "api/breakdown-pdf.js": {
      "maxDuration": 60,
      "memory": 2048,
      "includeFiles": "node_modules/@sparticuz/chromium/**"
    },
    "api/marketing-reconcile.js": {
      "maxDuration": 60
    },
    "api/marketing-publish.js": {
      "maxDuration": 60
    },
    "api/agents/daily.js": {
      "maxDuration": 60
    },
    "api/agents/weekly.js": {
      "maxDuration": 60
    },
    "api/agents/briefing.js": {
      "maxDuration": 60
    },
    "api/agents/memory.js": {
      "maxDuration": 60
    },
    "api/agents/watchdog.js": {
      "maxDuration": 30
    },
    "api/agents/heartbeat.js": {
      "maxDuration": 30
    },
    "api/agents/cashflow.js": {
      "maxDuration": 60
    },
    "api/agents/peer-audit.js": {
      "maxDuration": 300
    },
    "api/agents/cron-daily.js": {
      "maxDuration": 300
    },
    "api/snapshot.js": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/marketing-reconcile",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/marketing-publish?next=1",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/agents/daily",
      "schedule": "3 10 * * *"
    },
    {
      "path": "/api/agents/weekly",
      "schedule": "7 9 * * 1"
    },
    {
      "path": "/api/agents/briefing?type=morning",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/agents/briefing?type=evening",
      "schedule": "0 21 * * *"
    },
    {
      "path": "/api/agents/memory",
      "schedule": "59 3 * * *"
    },
    {
      "path": "/api/agents/watchdog",
      "schedule": "0 12,14,16,18,20,22 * * *"
    },
    {
      "path": "/api/agents/heartbeat",
      "schedule": "30 12 * * *"
    },
    {
      "path": "/api/agents/cashflow",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/agents/peer-audit",
      "schedule": "30 10 * * *"
    },
    {
      "path": "/api/agents/cron-daily",
      "schedule": "45 10 * * *"
    }
  ]
}
