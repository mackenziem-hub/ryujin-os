{
  "rewrites": [
    { "source": "/api/agents/:agent((?!daily|weekly|briefing|memory|watchdog|heartbeat|cashflow|peer-audit|cron-daily|production|generator|inbox|questscan).*)", "destination": "/api/agents/[agent]?agent=:agent" },
    { "source": "/api/graph/:noun", "destination": "/api/graph/[noun]?noun=:noun" },
    { "source": "/i/:slug", "destination": "/api/i?u=:slug" },
    { "source": "/proposals/custom/:slug", "destination": "/custom-proposal.html?slug=:slug" },
    { "source": "/(.*)", "destination": "/public/$1" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization, x-tenant-id, x-internal-key" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, must-revalidate" }
      ]
    }
  ],
  "functions": {
    "api/marketing-render.js": {
      "maxDuration": 300,
      "includeFiles": "node_modules/ffmpeg-static/**"
    },
    "api/marketing.js": {
      "maxDuration": 60
    },
    "api/marketing-upload-token.js": {
      "maxDuration": 30
    },
    "api/chat.js": {
      "maxDuration": 60
    },
    "api/proposal-pdf.js": {
      "maxDuration": 60,
      "memory": 2048,
      "includeFiles": "node_modules/@sparticuz/chromium/**"
    },
    "api/contract-pdf.js": {
      "maxDuration": 60,
      "memory": 2048,
      "includeFiles": "node_modules/@sparticuz/chromium/**"
    },
    "api/docs-pdf.js": {
      "maxDuration": 60,
      "memory": 2048,
      "includeFiles": "node_modules/@sparticuz/chromium/**"
    },
    "api/breakdown-pdf.js": {
      "maxDuration": 60,
      "memory": 2048,
      "includeFiles": "node_modules/@sparticuz/chromium/**"
    },
    "api/page-pdf.js": {
      "maxDuration": 60,
      "memory": 2048,
      "includeFiles": "node_modules/@sparticuz/chromium/**"
    },
    "api/before-after-generate.js": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "lib/assets/fonts/**"
    },
    "api/marketing-reconcile.js": {
      "maxDuration": 60
    },
    "api/marketing-publish.js": {
      "maxDuration": 60
    },
    "api/agents/daily.js": {
      "maxDuration": 60
    },
    "api/agents/weekly.js": {
      "maxDuration": 60
    },
    "api/agents/briefing.js": {
      "maxDuration": 300
    },
    "api/agents/memory.js": {
      "maxDuration": 60
    },
    "api/agents/watchdog.js": {
      "maxDuration": 30
    },
    "api/agents/heartbeat.js": {
      "maxDuration": 30
    },
    "api/agents/cashflow.js": {
      "maxDuration": 60
    },
    "api/agents/peer-audit.js": {
      "maxDuration": 300
    },
    "api/agents/cron-daily.js": {
      "maxDuration": 300
    },
    "api/agents/generator.js": {
      "maxDuration": 120,
      "memory": 1024,
      "includeFiles": "lib/assets/fonts/**"
    },
    "api/generator.js": {
      "maxDuration": 60
    },
    "api/agents/inbox.js": {
      "maxDuration": 120
    },
    "api/agents/questscan.js": {
      "maxDuration": 60
    },
    "api/snapshot.js": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/marketing-reconcile",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/marketing-publish?next=1",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/agents/daily",
      "schedule": "3 10 * * *"
    },
    {
      "path": "/api/agents/weekly",
      "schedule": "7 9 * * 1"
    },
    {
      "path": "/api/agents/briefing?type=morning",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/agents/briefing?type=evening",
      "schedule": "0 21 * * *"
    },
    {
      "path": "/api/agents/memory",
      "schedule": "59 3 * * *"
    },
    {
      "path": "/api/agents/watchdog",
      "schedule": "0 12,14,16,18,20,22 * * *"
    },
    {
      "path": "/api/agents/heartbeat",
      "schedule": "30 12 * * *"
    },
    {
      "path": "/api/agents/cashflow",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/agents/peer-audit",
      "schedule": "30 10 * * *"
    },
    {
      "path": "/api/agents/cron-daily",
      "schedule": "45 10 * * *"
    },
    {
      "path": "/api/agents/production?tenant=plus-ultra",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/feeders/drive-job-folders?tenant=plus-ultra",
      "schedule": "*/20 * * * *"
    },
    {
      "path": "/api/feeders/ghl-job-artifacts?tenant=plus-ultra",
      "schedule": "10,40 * * * *"
    },
    {
      "path": "/api/agents/generator",
      "schedule": "0 23 * * 0"
    },
    {
      "path": "/api/agents/inbox?tenant=plus-ultra",
      "schedule": "*/20 * * * *"
    },
    {
      "path": "/api/agents/questscan?tenant=plus-ultra",
      "schedule": "45 11 * * *"
    }
  ]
}
