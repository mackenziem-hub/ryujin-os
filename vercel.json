{
  "rewrites": [
    {
      "source": "/api/agents/:agent((?!daily|weekly|briefing|memory|watchdog|heartbeat|cashflow|peer-audit|cron-daily|production|generator|inbox|questscan|reconcile|canary).*)",
      "destination": "/api/agents/[agent]?agent=:agent"
    },
    {
      "source": "/api/graph/:noun",
      "destination": "/api/graph/[noun]?noun=:noun"
    },
    {
      "source": "/i/:slug",
      "destination": "/api/i?u=:slug"
    },
    {
      "source": "/proposals/custom/:slug",
      "destination": "/custom-proposal.html?slug=:slug"
    },
    {
      "source": "/p/:slug",
      "destination": "/proposal-v2.html?instance=:slug"
    },
    {
      "source": "/c/:slug",
      "destination": "/contract-v2.html?instance=:slug"
    },
    {
      "source": "/(.*)",
      "destination": "/public/$1"
    }
  ],
  "redirects": [
    {
      "source": "/cockpit",
      "destination": "/cockpit.html",
      "permanent": false
    },
    {
      "source": "/62-charlotte-roof-proposal.html",
      "destination": "/proposal-client.html?share=JI639ircHmr2JGEelAhJRO6eAkPBm482",
      "permanent": false
    },
    {
      "source": "/652-principale-roof-proposal.html",
      "destination": "/p/652-rue-principale-f8ed1f",
      "permanent": false
    },
    {
      "source": "/p/652-rue-principale-275528",
      "destination": "/p/652-rue-principale-f8ed1f",
      "permanent": false
    },
    {
      "source": "/p/652-rue-principale-5fadf3",
      "destination": "/p/652-rue-principale-f8ed1f",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization, x-tenant-id, x-internal-key"
        }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, max-age=0"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, max-age=0"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/(admin|admin-archives|admin-job-log|admin-portals|cockpit|inbox|customer-list|customer-profile|customer-admin|customer-reviews|command-center|builder-room|agent-ops|login|job|app|annotate|generator|finance-admin|finance-payments|finance-pl|finance-receivables|marketing-admin|production-admin|sales-admin|service-admin|service-tickets|portal-mobile|internal-deck|deck-decisions|deck-marketing-doctrine)\\.html",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    },
    {
      "source": "/p/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ],
