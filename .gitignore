node_modules/
.next/
.env
.env.local
.env.production
.env.*.local
.env.vercel-*
.vercel

# Machine-local OneDrive conflict copies
*-DESKTOP-71KPCBP*
*-DESKTOP-71KPCBP-2*
*-HAL*

# Large media files (>100MB GitHub limit) — store via Vercel Blob instead
public/content/*.mp4
*.log
.DS_Store
Thumbs.db
scripts/photos-to-upload/*
!scripts/photos-to-upload/.gitkeep

# One-shot scripts containing secrets (crew magic-link tokens, etc.)
scripts/_oneshot/_crew_magic_links_*.json

# Local-only RPG art source: full-res sector masters + superseded backups.
# Relocated out of the repo root and public/assets/rpg so they stop riding
# along on every `vercel --prod` upload (~14 MB). Kept in the working tree,
# never tracked or shipped. Vercel honors .gitignore for deploy uploads.
art-source/
# Defensive: any stray _backup_* art left under public/ should never deploy.
public/**/_backup_*/
.maryphotos/
